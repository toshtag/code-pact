{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "corpus_version",
    "case_id",
    "variant",
    "executor_id",
    "replicate",
    "fixture_digest",
    "task_contract_digest",
    "task_contract_sha256",
    "max_rounds",
    "base_commit",
    "tool_permission_class",
    "fresh_session_required",
    "input_bundle_sha256",
    "manifest_sha256",
    "workspace_path",
    "rounds_path",
    "executor_input_path",
    "instruction_path",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "corpus_version": { "type": "string", "minLength": 1 },
    "case_id": { "type": "string", "minLength": 1 },
    "variant": { "enum": ["baseline", "code_pact"] },
    "executor_id": { "type": "string", "minLength": 1 },
    "replicate": { "type": "integer", "minimum": 1 },
    "fixture_digest": { "type": "string", "minLength": 1 },
    "task_contract_digest": { "type": "string", "minLength": 1 },
    "task_contract_sha256": { "type": "string", "minLength": 1 },
    "max_rounds": { "type": "integer", "minimum": 1 },
    "base_commit": { "type": "string", "minLength": 1 },
    "tool_permission_class": { "type": "string", "minLength": 1 },
    "fresh_session_required": { "type": "boolean" },
    "input_bundle_sha256": { "type": "string", "minLength": 1 },
    "manifest_sha256": { "type": "string", "minLength": 1 },
    "initial_code_pact_stdout_bytes": { "type": "integer", "minimum": 0 },
    "workspace_path": { "type": "string", "minLength": 1 },
    "rounds_path": { "type": "string", "minLength": 1 },
    "executor_input_path": { "type": "string", "minLength": 1 },
    "instruction_path": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "stage": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
