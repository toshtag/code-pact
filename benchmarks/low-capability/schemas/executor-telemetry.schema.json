{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "executor_id",
    "variant",
    "replicate",
    "session_id",
    "tool_permission_class",
    "input_tokens",
    "output_tokens",
    "billed_amount",
    "currency",
    "manual_intervention_count"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "executor_id": { "type": "string", "minLength": 1 },
    "variant": { "enum": ["baseline", "code_pact"] },
    "replicate": { "type": "integer", "minimum": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "tool_permission_class": { "type": "string", "minLength": 1 },
    "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "billed_amount": { "type": ["number", "null"], "minimum": 0 },
    "currency": { "type": ["string", "null"], "minLength": 1 },
    "manual_intervention_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
