{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "corpus_version",
    "max_rounds",
    "paired_count",
    "by_executor",
    "by_case",
    "totals",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "corpus_version": { "type": "string", "minLength": 1 },
    "max_rounds": { "type": "integer", "minimum": 1 },
    "paired_count": { "type": "integer", "minimum": 0 },
    "by_executor": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "executor_id",
          "baseline_runs",
          "code_pact_runs",
          "baseline_successful_outcome_rate",
          "code_pact_successful_outcome_rate"
        ],
        "additionalProperties": true
      }
    },
    "by_case": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "paired_count",
          "baseline_verified_success_rate",
          "code_pact_verified_success_rate"
        ],
        "additionalProperties": true
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "baseline_runs",
        "code_pact_runs",
        "baseline_successful_outcomes",
        "code_pact_successful_outcomes",
        "baseline_verified_success_count",
        "code_pact_verified_success_count",
        "baseline_expected_stop_success_count",
        "code_pact_expected_stop_success_count",
        "baseline_scope_violation_count",
        "code_pact_scope_violation_count",
        "baseline_first_pass_success_count",
        "code_pact_first_pass_success_count",
        "baseline_decision_stop_unnecessary_count",
        "code_pact_decision_stop_unnecessary_count",
        "baseline_tokens_per_successful_outcome",
        "code_pact_tokens_per_successful_outcome",
        "token_efficiency_conclusion",
        "safety_gate",
        "efficiency_signal",
        "stage_b_allowed"
      ],
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
