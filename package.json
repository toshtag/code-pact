{
  "name": "code-pact",
  "version": "2.1.0",
  "description": "Design Control Plane for AI Coding Agents",
  "type": "module",
  "license": "MIT",
  "author": "Pocket (@toshtag)",
  "homepage": "https://github.com/toshtag/code-pact#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toshtag/code-pact.git"
  },
  "bugs": {
    "url": "https://github.com/toshtag/code-pact/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "claude",
    "codex",
    "design",
    "spec-driven"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.34.2",
  "bin": {
    "code-pact": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration:smoke": "vitest run --config vitest.integration.smoke.config.ts",
    "test:integration:full": "pnpm build && vitest run --config vitest.integration.config.ts",
    "test:integration": "pnpm test:integration:full",
    "test:ci": "pnpm check:supply-chain && pnpm typecheck && pnpm test:unit && pnpm build && pnpm test:integration:smoke && node dist/cli.js --version && node dist/cli.js --json --version",
    "test:cli:init-smoke": "node scripts/run-init-smoke.mjs",
    "test:ci:deep": "pnpm check:docs && pnpm check:fs-containment && pnpm check:fs-authority && pnpm check:security-hardening && pnpm check:supply-chain && pnpm typecheck && pnpm test:unit && pnpm build && vitest run --config vitest.integration.config.ts && node dist/cli.js plan lint --include-quality --strict --json && node dist/cli.js plan analyze --strict --json && pnpm test:cli:init-smoke",
    "test:watch": "vitest",
    "prepush:fast": "pnpm test:ci",
    "prepush:deep": "pnpm test:ci:deep",
    "typecheck": "tsc --noEmit",
    "check:doc-links": "tsx scripts/check-doc-links.ts",
    "check:public-md-links": "tsx scripts/check-public-md-links.ts",
    "check:doc-invariants": "node scripts/check-doc-invariants.mjs",
    "check:history-noise": "node scripts/check-history-noise.mjs",
    "check:changelog-archive": "node scripts/changelog-archive.mjs --check",
    "changelog:archive": "node scripts/changelog-archive.mjs --write",
    "release-notes": "node scripts/release-notes.mjs",
    "gen:cli-reference": "tsx scripts/gen-cli-reference.ts",
    "check:cli-reference": "tsx scripts/gen-cli-reference.ts --check",
    "gen:doc-blocks": "tsx scripts/gen-doc-blocks.ts",
    "check:doc-blocks": "tsx scripts/gen-doc-blocks.ts --check",
    "check:docs": "pnpm check:doc-links && pnpm check:public-md-links && pnpm check:doc-invariants && pnpm check:history-noise && pnpm check:changelog-archive && pnpm check:cli-reference && pnpm check:doc-blocks",
    "check:release-version": "node scripts/check-release-version.mjs",
    "check:fs-containment": "node scripts/check-fs-containment.mjs",
    "check:fs-authority": "node scripts/check-fs-authority.mjs",
    "check:security-hardening": "node scripts/check-security-hardening-invariants.mjs",
    "check:release-tag": "node scripts/check-release-tag.mjs",
    "check:package-tarball": "node scripts/check-package-tarball.mjs",
    "verify:published-tarball": "node scripts/verify-published-tarball.mjs",
    "check:supply-chain": "node scripts/check-supply-chain-invariants.mjs && pnpm check:toolchain-binaries",
    "release:check": "pnpm typecheck && pnpm test && pnpm check:docs && pnpm check:fs-containment && pnpm check:fs-authority && pnpm check:security-hardening && pnpm check:supply-chain && pnpm check:release-version && node dist/cli.js validate --json && node dist/cli.js plan lint --include-quality --strict --json && node dist/cli.js plan analyze --strict --json",
    "check:toolchain-binaries": "node scripts/check-toolchain-binaries.mjs"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "0.28.1",
    "github-slugger": "^2.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "typescript-compiler-api": "npm:typescript@6.0.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.6"
  }
}
